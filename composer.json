{
    "name": "kejubayer/kej-stock-market",
    "description": "Laravel package to fetch DSE and CSE live stock market data as arrays",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "stock market", "DSE", "CSE", "bangladesh", "finance"],
    "authors": [
        {
            "name": "Kejubayer",
            "email": "khondokereftakharjubayer@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Kejubayer\\StockMarket\\": "src/"
        }
    },
    "require": {
        "php": ">=7.4",
        "illuminate/support": "^8.0|^9.0|^10.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kejubayer\\StockMarket\\KejStockMarketServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
